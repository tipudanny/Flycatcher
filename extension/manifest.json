{
  "manifest_version": 3,
  "name": "Flycatcher — Webhook Inspector",
  "version": "1.0.0",
  "description": "Live desktop notifications and a badge count for webhooks captured by your Flycatcher inspector.",
  "action": {
    "default_title": "Flycatcher — open inspector",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://localhost/*", "http://127.0.0.1/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "alarms", "notifications", "cookies", "sidePanel", "tabs"],
  "host_permissions": ["http://localhost/*", "http://127.0.0.1/*", "https://*/*"]
}
